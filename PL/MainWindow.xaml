<Window x:Class="PL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL"
        mc:Ignorable="d"
        Title="Login" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Icon="/BigIcon.png">

    <Window.Resources>
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource AyeletHardColor}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource HardGreenColor}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid Background="{DynamicResource CreamColor}">
        <Grid.RowDefinitions>
            <RowDefinition />
            <!-- Logo space -->
            <RowDefinition Height="Auto" MinHeight="271"/>

            <RowDefinition Height="Auto" MinHeight="133.04"/>
            <RowDefinition Height="0*"/>
        </Grid.RowDefinitions>

        <!-- Logo Space -->
        <Image Grid.Row="0" 
               Margin="5,5,5,5"
               Source="/LOGO (3).png" />
        <!-- Replace with your logo path -->
        <GroupBox Grid.Row="1" Background="{StaticResource AyeletLightColor}" Style="{StaticResource FormGroupBoxStyle}" Margin="100,5,100,5">
            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel 
            Margin="50,5" Grid.Row="0">
                    <TextBlock Text="ID" 
               Margin="0,0,0,0"
               FontSize="14"
               Foreground="{StaticResource AyeletHardColor}"/>
                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                             Background="White" BorderThickness="3"
                             Foreground="{StaticResource AyeletHardColor}"
                             FontFamily="Trebuchet MS"
                             Text="{Binding Id, Mode=TwoWay}"
                             TextChanged="ID_TextChanged"
                             KeyDown="ID_KeyDown" Height="43"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="50,7,50,0">

                    <TextBlock Text="Password"
                               Margin="0,0,0,5"
                               FontFamily="Trebuchet MS"
                               Foreground="{StaticResource AyeletHardColor}"/>
                    <Grid>
                        <PasswordBox Style="{StaticResource LoginPasswordBoxStyle}"
                                 PasswordChar="●"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 KeyDown="TextBox_KeyDown" Height="43" Panel.ZIndex="2"
                                 Visibility="Visible"/>

                        <!--<TextBox  Style="{StaticResource FormTextBoxStyle}"
                              Text="{Binding ElementName=passwordBox, Path=Password, Mode=TwoWay}"
                              KeyDown="TextBox_KeyDown"
                              Height="43"
                              Visibility="Collapsed"/>
                    <Button Content="👁"
                            Width="30"  Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Click="ShowPasswordButton_Click"/>-->
                    </Grid>

                </StackPanel>
            </Grid>
        </GroupBox>
        <!-- Login Controls -->


        <Button Grid.Row="1"
                Content="Login"
                Style="{StaticResource MainButtonStyle}"
                Click="btn_Login"
                Margin="300,209,300,19"/>

        <Image HorizontalAlignment="Left" VerticalAlignment="Bottom" Grid.Row="1" Grid.RowSpan="2"
               Source="/LOGO (4).png" Margin="10,0,0 10" RenderTransformOrigin="0.5,0.5" Panel.ZIndex="1" Height="263" Width="304"/>

    </Grid>
</Window>
