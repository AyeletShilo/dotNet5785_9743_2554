<Window x:Class="PL.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL"
        mc:Ignorable="d"
        Title="Login" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Icon="/Image/ICON.ico">

    <Window.Resources>
        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource AyeletHardColor}"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource HardGreenColor}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <!--<Setter Property="Cursor" Value="Hand"/>-->
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid Background="{DynamicResource CreamColor}">
        <Grid.RowDefinitions>
            <!-- Logo space -->
            <RowDefinition Height="5*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- Replace with your logo path -->
        <GroupBox Grid.Row="0" Background="{StaticResource AyeletLightColor}" Style="{StaticResource FormGroupBoxStyle}" Margin="100,50,100,5">

            <Grid Grid.Row="1" Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="4*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo Space -->
                <Image Grid.Row="0" 
                       Margin="5,5,5,5"
                       Source="/Image/LOGO (3).png" />
                <StackPanel  
                    Margin="50,5" Grid.Row="1">
                    <TextBlock Text="ID" 
                               Margin="0,0,0,0"
                               FontSize="14"
                               Foreground="{StaticResource AyeletHardColor}"/>
                    <TextBox Style="{StaticResource FormTextBoxStyle}"
                             Background="White" BorderThickness="3"
                             Foreground="{StaticResource AyeletHardColor}"
                             FontFamily="Trebuchet MS"
                             Text="{Binding Id, Mode=TwoWay}"
                             TextChanged="ID_TextChanged"
                             Cursor="Hand"
                             KeyDown="ID_KeyDown" Height="43"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="50,7,50,0">

                    <TextBlock Text="Password"
                               Margin="0,0,0,5"
                               FontFamily="Trebuchet MS"
                               Foreground="{StaticResource AyeletHardColor}"/>
                    <Grid>
                        <PasswordBox Style="{StaticResource LoginPasswordBoxStyle}"
                                 PasswordChar="●"
                                 PasswordChanged="PasswordBox_PasswordChanged"
                                 KeyDown="TextBox_KeyDown" Height="43" Panel.ZIndex="1"
                                 Visibility="Visible"/>

                        <!--<TextBox  Style="{StaticResource FormTextBoxStyle}"
                              Text="{Binding ElementName=passwordBox, Path=Password, Mode=TwoWay}"
                              KeyDown="TextBox_KeyDown"
                              Height="43"
                              Visibility="Collapsed"/>
                    <Button Content="👁"
                            Width="30"  Height="30"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Click="ShowPasswordButton_Click"/>-->
                    </Grid>

                </StackPanel>
            </Grid>
        </GroupBox>
        <!-- Login Controls -->


        <Button Grid.Row="0" Grid.RowSpan="2"
                Content="Login"
                Style="{StaticResource MainButtonStyle}"
                Click="btn_Login"
                VerticalAlignment="Top"
                Margin="300,470,300,0" Height="46"/>

        <Image HorizontalAlignment="Right" VerticalAlignment="Bottom"
               Source="/Image/LOGO (4).png" Margin="0,0,0,10" RenderTransformOrigin="0.5,0.5" Panel.ZIndex="1" Height="232" Width="261" Grid.RowSpan="2"/>

    </Grid>
</Window>
