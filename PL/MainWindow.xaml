        <Style x:Key="LoginPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource HardGreenColor}"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Logo space -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto" MinHeight="45"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <!-- Logo Space -->
        <Image Grid.Row="0" 
               Margin="106,-21,106,65"
               Stretch="Uniform"
               Source="/LOGO (3).png" Grid.RowSpan="3"/>
        <!-- Replace with your logo path -->

        <!-- Login Controls -->
        <StackPanel Grid.Row="1" 
                    Margin="50,0,50,20" Grid.RowSpan="2">
            <TextBlock Text="ID" 
                       Margin="0,0,0,5"
                       FontSize="14"
                       Foreground="{StaticResource HardestGreenColor}"/>
            <TextBox Style="{StaticResource FormTextBoxStyle}"
                     Background="White" BorderThickness="3"
                     Text="{Binding Id, Mode=TwoWay}"
                     TextChanged="ID_TextChanged"
                     KeyDown="ID_KeyDown" Height="43"/>
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="50,0,50,30" Grid.RowSpan="2">
            <TextBlock Text="Password"
                       Margin="0,0,0,5"
                       FontSize="14"
                       Foreground="{StaticResource HardestGreenColor}"/>
            <PasswordBox Style="{StaticResource LoginPasswordBoxStyle}"
                        PasswordChar="●"
                        PasswordChanged="PasswordBox_PasswordChanged"
                        KeyDown="TextBox_KeyDown"/>
        </StackPanel>

        <Button Grid.Row="5"
                Content="Login"
                Style="{StaticResource MainButtonStyle}"
                Click="btn_Login"
                Margin="300,0,300,7"/>
    </Grid>
</Window>

