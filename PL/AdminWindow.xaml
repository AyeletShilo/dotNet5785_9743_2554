<Window x:Class="PL.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL"
        mc:Ignorable="d"
        Title="AdminWindow" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}" 
        Background="{StaticResource CreamColor}"
        Closed="Window_Closed"
        Loaded="ScreenLoaded">

    <Window.Resources>
        <Style x:Key="MaterialDropShadow" TargetType="Border">
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect
                Color="Black"
                Direction="320"
                ShadowDepth="5"
                Opacity="0.5"
                BlurRadius="10" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TimeButton" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource CreamColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource HardGreenColor}"/>
            <Setter Property="FontFamily" Value="Comic Sans MS"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="{StaticResource AyeletHardColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="AmountButtons" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource CreamColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource AyeletColor}"/>
            <Setter Property="FontFamily" Value="Trebuchet MS"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource HardestGreenColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="DataButtons" TargetType="Button" BasedOn="{StaticResource RoundedButton}">
            <Setter Property="Background" Value="{StaticResource AyeletColor}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CreamColor}"/>
            <Setter Property="FontFamily" Value="Ariel"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="Foreground" Value="{StaticResource CreamColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>


    </Window.Resources>


    <!--Config-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="164.015"/>
            <RowDefinition Height="270.025"/>
        </Grid.RowDefinitions>

        <Button Style="{StaticResource BackArrowButton}"
                Click="BackButton_Click"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10,10,0,0"
                Panel.ZIndex="1"/>
        
        <!--Time Defination-->
        <Border Grid.Row="0" 
        Background="{StaticResource Greeny}"
        CornerRadius="25" 
        Padding="10"
        Margin="125,20,125,20">
            <!--Effect="{StaticResource MaterialDropShadow}">-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!--clock-->
                <Label  Grid.Row="0" 
                        Style="{StaticResource BaseLabel}"
                        Content="{Binding CurrentDate}" 
                        FontFamily="Comic Sans MS"
                        FontSize="30"
                        Foreground="White"
                        FontWeight="Bold"
                        Margin="0,0,0,5"/>
                <!--ForWard Clock-->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Content="+Year" 
                            Click="btnAddOneYear_Click"
                            Style="{StaticResource TimeButton}"
                            HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="1"
                            Content="+Month" 
                            Click="btnAddOneMonth_Click"                            
                            Style="{StaticResource TimeButton}"
                            HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="2"
                            Content="+Day " 
                            Click="btnAddOneDay_Click"
                            Style="{StaticResource TimeButton}"
                            HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="3"
                            Content="+Hour" 
                            Click="btnAddOneHour_Click"
                            Style="{StaticResource TimeButton}"
                            HorizontalAlignment="Stretch"/>
                    <Button Grid.Column="4"
                            Content="+Minute" 
                            Click="btnAddOneMinute_Click"
                            Style="{StaticResource TimeButton}"
                            HorizontalAlignment="Stretch"/>
                </Grid>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="0,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="333"/>
                <ColumnDefinition Width="467"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="106.01"/>
                    <RowDefinition Height="164.015"/>
                </Grid.RowDefinitions>

                <Border Grid.Column="1" Grid.Row="0"
                    Background="{StaticResource AyeletLightColor}"
                    CornerRadius="15" 
                    Padding="5"
                    Margin="5,0,10,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <UniformGrid Columns="1" Grid.Column="0">
                            <Button Click="Opened_Click" 
                                 Content="{Binding CallsAmount[0], Mode=TwoWay}" 
                                 ContentStringFormat="⚡Opened Calls: {0}"
                                 Style="{StaticResource AmountButtons}"
                                 Margin="5,5,0,0"
                                Width="Auto" Height="Auto"/>

                            <Button  Click="Treatment_Click"
                                 Content="{Binding CallsAmount[1], Mode=TwoWay}"
                                 ContentStringFormat="🔧 In treatment: {0}" 
                                 Style="{StaticResource AmountButtons}"
                                 Margin="5,5,0,0"
                                 Height="Auto"/>

                            <Button  Click="Closed_Click"
                                     Content="{Binding CallsAmount[2], Mode=TwoWay}"
                                     ContentStringFormat="✅ Closed: {0}"
                                     Style="{StaticResource AmountButtons}"
                                     Margin="5,5,0,0"
                                     Height="Auto"/>
                        </UniformGrid>
                        <UniformGrid Columns="1" Grid.Column="1">
                            <Button Click="Expired_Click" 
                                    Content="{Binding CallsAmount[3], Mode=TwoWay}" 
                                    ContentStringFormat="⏰ Expired Calls: {0}"
                                    Style="{StaticResource AmountButtons}"
                                    Margin="5,5,0,0"
                                    Width="Auto" Height="Auto"/>

                            <Button  Click="OpenRisk_Click"
                                     Content="{Binding CallsAmount[4], Mode=TwoWay}"
                                     ContentStringFormat="⚡⚠️ Open in risk: {0}" 
                                     Style="{StaticResource AmountButtons}"
                                     Margin="5,5,0,0"
                                     Height="Auto"/>

                            <Button  Click="TreatmentRisk_Click"
                                     Content="{Binding CallsAmount[5], Mode=TwoWay}"
                                     ContentStringFormat="🔧⚠️ In treatment in risk: {0}"
                                     Style="{StaticResource AmountButtons}"
                                     Margin="5,5,0,0"
                                     Height="Auto"/>
                        </UniformGrid>
                        <!--<StackPanel Grid.Column="0" Margin="5,0,0,5" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                        <Button Click="Opened_Click" 
                                Content="{Binding CallsAmount[0], Mode=TwoWay}" 
                                ContentStringFormat="⚡Opened Calls: {0}"
                                Style="{StaticResource AmountButtons}"
                                Margin="5,5,0,0"
                                Width="Auto" Height="Auto"/>

                        <Button  Click="Treatment_Click"
                                 Content="{Binding CallsAmount[1], Mode=TwoWay}"
                                 ContentStringFormat="🔧 In treatment: {0}" 
                                 Style="{StaticResource AmountButtons}"
                                 Margin="5,5,0,0"
                                 Height="Auto"/>

                        <Button  Click="Closed_Click"
                                 Content="{Binding CallsAmount[2], Mode=TwoWay}"
                                 ContentStringFormat="✅ Closed: {0}"
                                 Style="{StaticResource AmountButtons}"
                                 Margin="5,5,0,0"
                                 Height="Auto"/>
                    </StackPanel>-->
                    </Grid>
                </Border>
                <Grid Grid.Row="1" Margin="0,0,10,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Button Content="InitializeDB"
                            Grid.Column="0" Grid.Row="0"
                            Click ="btnInitializeDB_Click" 
                            Style="{StaticResource DataButtons}"
                            Margin="10,5,10,5"/>
                    <Button Content="Handle Volunteers" 
                            Grid.Column="1" Grid.Row="1"
                            Click="btnVolunteer_Click"
                            Style="{StaticResource DataButtons}"
                            FontSize="24" 
                            Margin="10,5,10,5" />
                    <Button Content="ResetDB" 
                            Grid.Column="1" Grid.Row="0"
                            Click="btnResetDB_Click" 
                            Style="{StaticResource DataButtons}"
                            Margin="10,5,10,5"/>
                    <Button Content = "Handle Calls"
                            Grid.Column="0" Grid.Row="1"
                            Click = "btnCall_Click"  
                            Style="{StaticResource DataButtons}"
                            Margin = "10,5,10,5"/>

                </Grid>
               
            </Grid>
            <StackPanel >
                <!--RiskRange-->
                <TextBox  Text="{Binding RiskRange, StringFormat='{}{0}'}" FontWeight="Bold" FontSize="20"/>
                <Button Content="Update Risk Range"
                        Click="btnUpdateRiskRange_Click" 
                        Style="{StaticResource CheerfulButton}"/>
            </StackPanel>
        </Grid>


        




    </Grid>
</Window>



