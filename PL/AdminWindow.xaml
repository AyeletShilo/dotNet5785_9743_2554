<Window x:Class="PL.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL"
        mc:Ignorable="d"
        Title="AdminWindow" Height="450" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}" 
        Closed="Window_Closed"
        Loaded="ScreenLoaded">

    <!--Config-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80*"/>
            <RowDefinition Height="100*"/>
        </Grid.RowDefinitions>

        <!--Clock-->
        <Grid Margin="205,0,215,10">
            <Label Content="{Binding CurrentDate}" FontWeight="Bold" FontSize="20" Margin="0,10,0,0" VerticalAlignment="Top" Height="50"/>
            <Button Content="Add One Minute" Click="btnAddOneMinute_Click" HorizontalAlignment="Stretch" Margin="0,80,0,0" VerticalAlignment="Top"/>
            <Button Content="Add One Hour" Click="btnAddOneHour_Click" HorizontalAlignment="Stretch" Margin="0,100,0,0" VerticalAlignment="Top"/>
            <Button Content="Add One Day " Click="btnAddOneDay_Click" HorizontalAlignment="Stretch" Margin="0,120,0,0" VerticalAlignment="Top"/>
            <Button Content="Add One Month" Click="btnAddOneMonth_Click" HorizontalAlignment="Stretch" Margin="0,140,0,0" VerticalAlignment="Top"/>
            <Button Content="Add One Year" Click="btnAddOneYear_Click" HorizontalAlignment="Stretch" Margin="0,160,0,0" VerticalAlignment="Top"/>
        </Grid>

        <!--RiskRange-->
        <TextBox HorizontalAlignment="Left" Margin="27,91,0,0" TextWrapping="Wrap" Text="{Binding RiskRange}" FontWeight="Bold" FontSize="20" VerticalAlignment="Top" Width="124" Height="26"/>
        <Button Content="Update Risk Range" Click="btnUpdateRiskRange_Click" HorizontalAlignment="Left" Margin="27,138,0,0" VerticalAlignment="Top" Height="26" Width="124"/>

        <Button Content="InitializeDB" Click ="btnInitializeDB_Click" HorizontalAlignment="Left" Margin="89,141,0,0" VerticalAlignment="Top" Height="40" Width="120" Grid.Row="1"/>
        <Button Content="Handle Volunteers" Click="btnVolunteer_Click" HorizontalAlignment="Center" Margin="0,146,0,0" VerticalAlignment="Top" Height="40" Width="120" Grid.Row="1"/>
        <Button Content="ResetDB" Click="btnResetDB_Click"  HorizontalAlignment="Left" Margin="89,47,0,0" VerticalAlignment="Top" Height="40" Width="120" Grid.Row="1"/>
        <Button Content = "Handle Calls" Click = "btnCall_Click" HorizontalAlignment = "Center" Margin = "0,47,0,0" VerticalAlignment = "Top" Height = "40" Width = "120" Grid.Row = "1" />

        
        <Grid Grid.Row="1" Margin="507,47,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Content="Opened" Grid.Row="0" Grid.Column="0" Click="Opened_Click"/>
            <Button Content="In treatment"  Grid.Row="1" Grid.Column="0" Click="Tretment_Click"/>
            <Button Content="Closed" Grid.Row="2" Grid.Column="0" Click="Closed_Click"/>
            <Button Content="Expired" Grid.Row="3" Grid.Column="0" Click="Expired_Click" />
            <Button Content="Open in risk" Grid.Row="4" Grid.Column="0" Click="OpenRisk_Click"/>
            <Button Content="In treatment in risk" Grid.Row="5" Grid.Column="0" Click="TretmentRisk_Click"/>
            
            <TextBox Text="{Binding CallsAmount[0], Mode=TwoWay}" Grid.Row="0" Grid.Column="1"/>
            <TextBox Text="{Binding CallsAmount[1], Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>
            <TextBox Text="{Binding CallsAmount[2], Mode=TwoWay}" Grid.Row="2" Grid.Column="1"/>
            <TextBox Text="{Binding CallsAmount[3], Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>
            <TextBox Text="{Binding CallsAmount[4], Mode=TwoWay}" Grid.Row="4" Grid.Column="1"/>
            <TextBox Text="{Binding CallsAmount[5], Mode=TwoWay}" Grid.Row="5" Grid.Column="1"/>

        </Grid>
        <Label Content="Amount of call according status:" HorizontalAlignment="Left" Margin="507,24,0,0" Grid.Row="1" VerticalAlignment="Top" Width="283"/>
    </Grid>
</Window>