<Window x:Class="PL.Volunteer.VolunteerDataWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Volunteer"
        mc:Ignorable="d"
        Title="VolunteerDataWindow" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Closed="Window_Closed"
        Loaded="Window_Loaded"
        Background="{StaticResource CreamColor}">

    <Window.Resources>
        <Style TargetType="Label" BasedOn="{StaticResource LabelStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}"/>
        <Style TargetType="ComboBox" BasedOn="{StaticResource  ComboBoxStyle}"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="67*"/>
            <RowDefinition Height="Auto" MinHeight="314"/>
            <RowDefinition Height="105*"/>
            <RowDefinition Height="138*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="1" Padding="10" Background="{StaticResource AyeletLightColor}" Margin="30,30,30,30" CornerRadius="8">
            
            <!-- Personal Details Section -->
            <GroupBox Header="Personal Details" Style="{StaticResource FormGroupBoxStyle}" Margin="10,5,10,5" >
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="7.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="7.5*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label  Grid.Row="0" Grid.Column="0"
                            Content="Full Name:"
                            Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding CurrentVolunteer.FullName, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                             Style="{StaticResource FormTextBoxStyle}" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Content="Phone:" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Style="{StaticResource FormTextBoxStyle}">
                        <TextBox.Text>
                            <Binding Path= "CurrentVolunteer.PhoneNumber" Mode= "TwoWay" NotifyOnValidationError="true" ValidatesOnExceptions="true" ValidatesOnDataErrors="true" >
                                <Binding.ValidationRules>
                                    <local:PhoneValidation/>
                                </Binding.ValidationRules >
                            </Binding >
                        </TextBox.Text>
                    </TextBox>
                             

                    <Label Grid.Row="2" Grid.Column="0"
                           Content="Email:" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"  Style="{StaticResource FormTextBoxStyle}">
                        <TextBox.Text>
                            <Binding Path= "CurrentVolunteer.Email" Mode= "TwoWay" NotifyOnValidationError="true" ValidatesOnExceptions="true" ValidatesOnDataErrors="true" >
                                <Binding.ValidationRules>
                                    <local:EmailValidation/>
                                </Binding.ValidationRules >
                            </Binding >
                        </TextBox.Text>
                    </TextBox>
                             
                    <Label Grid.Row="0" Grid.Column="3"
                           Content="Password:" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Style="{StaticResource FormTextBoxStyle}">
                        <TextBox.Text>
                            <Binding Path= "CurrentVolunteer.Password" Mode= "TwoWay" NotifyOnValidationError="true" ValidatesOnExceptions="true" ValidatesOnDataErrors="true" >
                                <Binding.ValidationRules>
                                    <local:PassValidation/>
                                </Binding.ValidationRules >
                            </Binding >
                        </TextBox.Text>
                        <TextBox.ToolTip>
                                <ToolTip Width="200" BorderBrush="{StaticResource AyeletHardColor}"  Background="{StaticResource CreamColor}"
                                   Foreground="{StaticResource AyeletHardColor}">

                                    <Border BorderBrush="Gray" BorderThickness="1" Padding="5">
                                        <TextBlock TextWrapping="Wrap" Text="A strong password contains at least 8 characters,
                                                                             an uppercase letter, a lowercase letter, a special symbol,
                                                                             and does not contain sequences of numbers or letters" FontSize="16"/>
                                    </Border>
                                </ToolTip>
                            </TextBox.ToolTip>
                        
                    </TextBox>
                             
                    <Label Grid.Row="1" Grid.Column="3"
                           Content="Address:" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="1" Grid.Column="4" 
                             Text="{Binding CurrentVolunteer.Address, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true }" 
                             Style="{StaticResource FormTextBoxStyle}"/>
                    <!--<TextBlock Grid.Row="4" 
          Text="{Binding CurrentVolunteer.Job}" />-->
                    
                    <Label Grid.Row="2" Grid.Column="3"
                           Content="Max distance from call:" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="4" Style="{StaticResource FormTextBoxStyle}">
                        <TextBox.Text>
                            <Binding Path= "CurrentVolunteer.MaxDis" Mode= "TwoWay" NotifyOnValidationError="true" ValidatesOnExceptions="true" ValidatesOnDataErrors="true" >
                                <Binding.ValidationRules>
                                    <local:DisValidation/>
                                </Binding.ValidationRules >
                            </Binding >
                        </TextBox.Text>
                    </TextBox>
                             
                    <!--<Label Content="Active Volunteer?" Grid.Row="3" Grid.Column="3"  Margin="0,10,0,16"/>-->
                    <CheckBox Grid.Row="3" Grid.Column="4" Content="Active Volunteer?"
                              IsChecked="{Binding CurrentVolunteer.IsActive, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                              IsEnabled="{Binding CurrentVolunteer.InCall, Converter={StaticResource ConvertActiveIsEnableKey}}"
                              Style="{StaticResource FormCheckBoxStyle}"/>
                </Grid>

            </GroupBox>


        </Border>
        <Button Grid.Row="3" Content="Update" 
                Click="Update_Click"
                Style="{StaticResource MainButtonStyle}" Margin="270,10,270,20"/>
        
        <Button Style="{StaticResource BackArrowButton}"
                Click="BackButton_Click"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10,10,0,0"
                Panel.ZIndex="1"/>
    </Grid>
</Window>
