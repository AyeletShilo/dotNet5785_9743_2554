<Window x:Class="PL.Volunteer.VolunteerForVolWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Volunteer"
        mc:Ignorable="d"
        Title="VolunteerForVolWindow" Height="450" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Closed="Window_Closed"
        Loaded="Window_Loaded">
    <Window.Background>
        <ImageBrush ImageSource="/Volunteer/Background.png" Stretch="UniformToFill"/>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="labelStyle" TargetType="Label">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Goudy Old Style"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#FFB24846"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="Height" Value="Auto"/>
        </Style>
    </Window.Resources>

    <!--main grid-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="19*"/>
            <RowDefinition Height="406*"/>
            <RowDefinition Height="19*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="8*"/>
            <ColumnDefinition Width="500*"/>
            <ColumnDefinition Width="8*"/>
        </Grid.ColumnDefinitions>
        <!--user name-->
        <Border Grid.Column="1" Grid.ColumnSpan="2" Grid.RowSpan="2" BorderBrush="AntiqueWhite" BorderThickness="1" Padding="0,1,1,1" CornerRadius="0,0,0,20" 
                HorizontalAlignment="Right" VerticalAlignment="Top" Height="248">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="95*"/>
                    <RowDefinition Height="63*"/>
                    <RowDefinition Height="29*"/>
                    <RowDefinition Height="34*"/>
                </Grid.RowDefinitions>

                <Border  Grid.Row="2" CornerRadius="50" Background="Transparent" Margin="6,15,192,7" Grid.RowSpan="2" >
                    <Button Background="Transparent" BorderThickness="0" Click="UpdateVol_Click">
                        <Image Source="C:\Users\Administrator\source\repos\newOne\PL\Image\editHope.png" Width="40" Height="38" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="false"/>
                                    <Trigger Property="ClickMode" Value="Press"/>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>

                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="70" Height="70">

                    <Ellipse Fill="#FFFFF2EE" />

                    <TextBlock Text="{Binding FirstLet}"
                       FontFamily="Cooper Black"
                               FontSize="40"
                               FontWeight="Bold" 
                               Foreground="#FFC5025A"
                               
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Grid>
                <Label Content="{Binding CurrentVolunteer.FullName}" ContentStringFormat="Welcome {0}" Grid.Row="1"
               HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
               FontFamily="Cooper Black" FontSize="16"/>
                <Label Content="{Binding CurrentVolunteer.Id}" Grid.Row="2" FontFamily="Monotype Corsiva" FontSize="18" 
               HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                <Label Content="{Binding CurrentVolunteer.Job}" Grid.Row="3" FontFamily="Monotype Corsiva" FontSize="16"
               HorizontalAlignment="Center" VerticalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            </Grid>
        </Border>
        <!--second grid-->
        <Grid Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,0,31,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="341*"/>
                <RowDefinition Height="56*"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320*"/>
                <ColumnDefinition Width="217*"/>
                <ColumnDefinition Width="224*"/>
            </Grid.ColumnDefinitions>
            <!--Total Calls-->
            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Center" Width="216" RenderTransformOrigin="0.5,0.5" Grid.RowSpan="2" Margin="0,312,0,0">
                <StackPanel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="-1"/>
                        <SkewTransform/>
                        <RotateTransform/>
                        <TranslateTransform/>
                    </TransformGroup>
                </StackPanel.RenderTransform>
                <Label Content="{Binding CurrentVolunteer.HandleCalls}" ContentStringFormat="Total handled calls: {0}"  Width="534" Style="{StaticResource LabelStyle}" />
                <Label Content="{Binding CurrentVolunteer.CancelCalls}" ContentStringFormat="Total canceled calls: {0}"  Width="230"  Style="{StaticResource LabelStyle}" />
                <Label Content="{Binding CurrentVolunteer.ExpiredCalls}" ContentStringFormat="Total expired calls: {0}" Width="230" Style="{StaticResource LabelStyle}" />
            </StackPanel>

            <!--CallDetails-->
            <Border BorderBrush="Black" BorderThickness="1" Padding="10" CornerRadius="3" Background="#FFFEF2EE"
                     Visibility="{Binding CurrentVolunteer.InCall, Converter={StaticResource NullToVisibilityConverterKey}}" Grid.Column="0" Height="Auto" Width="Auto" Margin="16,0,16,1">
                <Grid  Background="#7FFFFFFF">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="37*"/>
                        <RowDefinition Height="37*"/>
                        <RowDefinition Height="37*"/>
                        <RowDefinition Height="37*"/>
                        <RowDefinition Height="23*"/>
                        <RowDefinition Height="30*"/>
                        <RowDefinition Height="37*"/>
                        <RowDefinition Height="56*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Grid.ColumnSpan="2" Content="{Binding CurrentCall.Id}" 
                           ContentStringFormat="Open Call: {0}" 
                           Height="Auto" Width="Auto"
                           FontFamily="Goudy Old Style"
                           Style="{StaticResource labelStyle}" 
                           HorizontalAlignment="Center"
                           FontSize="18" FontWeight="Bold" Foreground="#34495E"/>


                    <Label Grid.Row="1" Grid.Column="0" Content="Call Type: " 
                           Style="{StaticResource labelStyle}" 
                           HorizontalAlignment="Left" Height="27" Width="72" FontWeight="Bold" Margin="53,0,0,0"/>
                    <Label Grid.Row="1" Grid.Column="1" Content="{Binding CurrentCall.CallType}" 
                           Style="{StaticResource labelStyle}" 
                           HorizontalAlignment="Left" Margin="10,0,0,0" Width="Auto" Height="Auto"/>

                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Content="{Binding CurrentCall.CallAddress}" 
                           Style="{StaticResource labelStyle}"
                           HorizontalAlignment="Center" Width="Auto" Height="Auto"/>

                    <Label Grid.Row="2" Grid.ColumnSpan="2" HorizontalAlignment="Center" 
                           Content="{Binding Distance}" Width="Auto" Height="Auto"/>
                    <Label Grid.Row="4" Content="Opening time:" 
                           Style="{StaticResource labelStyle}" FontWeight="SemiBold" VerticalAlignment="Top" Height="26" Width="120" Grid.RowSpan="2" />
                    <Label Grid.Row="5" Content="{Binding CurrentCall.OpenTime}" 
                           Style="{StaticResource labelStyle}" VerticalAlignment="Top" Width="Auto" Height="Auto"/>
                    <Label Grid.Row="4" Grid.Column="1" Content="Open until:" 
                           Visibility="{Binding CurrentCall.MaxCloseTime, Converter={StaticResource NullToVisibilityConverterKey}}" 
                           Style="{StaticResource labelStyle}" FontWeight="SemiBold" Width="Auto" Height="Auto" VerticalAlignment="Top" Grid.RowSpan="2"/>
                    <Label Grid.Row="5" Grid.Column="1" Content="{Binding CurrentCall.MaxCloseTime}" 
                           Style="{StaticResource labelStyle}" VerticalAlignment="Top" FontFamily="Gabriola" Width="Auto" Height="Auto"/>
                    <Label Grid.Row="6" Grid.ColumnSpan="2" Content="{Binding CurrentCall.Status}" ContentStringFormat="Status- {0}"
                           Style="{StaticResource labelStyle}" HorizontalAlignment="Center"/>

                    <Border Grid.Row="7" Grid.ColumnSpan="2" Background="#FFF4F4F4" CornerRadius="5, 5,0,0" Padding="4">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <TextBlock TextWrapping="Wrap" FontFamily="Goudy Old Style" FontSize="14" Foreground="#FFB24846">
                            <Run Text="Call details: " FontWeight="SemiBold"/>
                            <Run Text="{Binding CurrentCall.Description}" />
                            </TextBlock>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>

            <!--<Button Grid.Row="1" Content="Update My details" Click="UpdateVol_Click" Margin="0,10,270,56" Grid.RowSpan="2"/>-->
            <Button Content="Chose new Call" Click="ChoseCall_Click" 
                    Grid.Row="0" Grid.Column="1" 
                    Width="Auto" Height="Auto"  
                    Style="{StaticResource RoundedButton}" Margin="16,10,100,261"
                    Background="#FFFEF2EE">
                <Button.IsEnabled>
                    <MultiBinding Converter="{StaticResource MultiToIsEnabledConverterKey}">
                        <Binding Path="CurrentVolunteer.InCall"/>
                        <Binding Path="CurrentVolunteer.IsActive"/>
                    </MultiBinding>
                </Button.IsEnabled>
            </Button>
            <Button Content="Previous calls" Click="HistoryCalls_Click" 
                    Width="Auto" Height="Auto" 
                    Grid.Column="1" Margin="78,100,38,171"
                    Style="{StaticResource RoundedButton}"
                    Background="#FFFEF2EE"/>
            <Image HorizontalAlignment="Left" Height="216"  VerticalAlignment="Top" Width="285" Source="/Image/GrandMa.png" Margin="270,181,0,0" Grid.ColumnSpan="3" Grid.RowSpan="2"/>
            <Button Background="Transparent" BorderThickness="0" Click="CancelTreatment_Click" Width="Auto" Height="Auto" 
                    Visibility="{Binding CurrentVolunteer.InCall, Converter={StaticResource NullToVisibilityConverterKey}}" Margin="81,318,179,23" Grid.RowSpan="2">
                <Image Source="/Volunteer/cancel3.png" Width="48" Height="46" HorizontalAlignment="Center" VerticalAlignment="Top"/>
                <!--resource??-->
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="False"/>
                            <Trigger Property="ClickMode" Value="Press"/>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Background="Transparent" BorderThickness="0" Click="EndTreatment_Click" Width="Auto" Height="Auto" Visibility="{Binding CurrentVolunteer.InCall, Converter={StaticResource NullToVisibilityConverterKey}}" Margin="163,312,84,16" Grid.RowSpan="2" >
                <Image Source="/Volunteer/check.png" Width="Auto" Height="Auto" />

                <!--resource??-->
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="false"/>
                            <Trigger Property="ClickMode" Value="Press"/>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

    </Grid>
</Window>

