<Window x:Class="PL.Volunteer.VolunteerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Volunteer"
        mc:Ignorable="d"
        Title="Volunteer Details" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Closed="Window_Closed"
        Loaded="Window_Loaded"
        Background="{StaticResource CreamColor}">

    <Grid>
        <Border Padding="10,5" Background="{StaticResource AyeletLightColor}" Margin="20,20,20,20" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="5*"/>
                    <RowDefinition Height="Auto" MinHeight="220"/>
                    <RowDefinition Height="27*"/>
                    <RowDefinition Height="Auto" MinHeight="186.041"/>
                    <RowDefinition Height="20*"/>
                </Grid.RowDefinitions>

                <!-- Personal Details Section -->
                <GroupBox Header="Personal Details" Grid.Row="1" Style="{StaticResource FormGroupBoxStyle}" Margin="2,2,2,2">
                    <Grid Margin="2.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4.5*"/>
                            <ColumnDefinition Width="7.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4.5*"/>
                            <ColumnDefinition Width="7.5*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Left Column -->
                        <Label Grid.Row="0" Grid.Column="0"
                           Content="ID:" 
                           Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="1" Grid.Row="0" 
                             Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding CurrentVolunteer.Id, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}"
                             IsReadOnly="{Binding ButtonText, Converter={StaticResource ConvertUpdateToTrueKey}}"/>

                        <Label Grid.Row="1" Grid.Column="0"
                           Content="Full Name:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Column="1" Grid.Row="1" 
                             Style="{StaticResource FormTextBoxStyle}"
                            Text="{Binding CurrentVolunteer.FullName, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}"/>

                        <Label Grid.Row="2" Grid.Column="0" 
                           Content="Phone:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Column="1" Grid.Row="2" Style="{StaticResource FormTextBoxStyle}" >
                            <TextBox.Text>
                                <Binding Path= "CurrentVolunteer.PhoneNumber" Mode= "TwoWay" NotifyOnValidationError="true" ValidatesOnExceptions="true" ValidatesOnDataErrors="true" >
                                    <Binding.ValidationRules>
                                        <local:DigitValidation/>
                                    </Binding.ValidationRules >
                                </Binding >
                            </TextBox.Text>
                        </TextBox>
                             

                        <!-- Additional Fields -->
                        <Label Grid.Row="3" Grid.Column="0" 
                           Content="Role:" Style="{StaticResource FormLabelStyle}" />
                        <ComboBox Grid.Column="1" Grid.Row="3" 
                              Margin="0,3"
                              SelectedValue="{Binding CurrentVolunteer.Job, Mode=TwoWay, NotifyOnValidationError=true}"
                              ItemsSource="{Binding Source={StaticResource RoleOptKey}}"
                              SelectionChanged="ComboBox_SelectionChanged"/>

                        <!-- Right Column -->
                        <Label Grid.Row="1" Grid.Column="3"
                           Content="Email:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Column="4" Grid.Row="1" 
                             Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding CurrentVolunteer.Email, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}"/>

                        <Label Grid.Row="2" Grid.Column="3"
                           Content="Address:" 
                           Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Column="4" Grid.Row="2" 
                             Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding CurrentVolunteer.Address, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}"/>

                        <Label Grid.Row="3" Grid.Column="3"
                           Content="Max Distance:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Column="4" Grid.Row="3" 
                             Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding CurrentVolunteer.MaxDis, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}"/>

                        <Label Grid.Row="0" Grid.Column="3"
                           Content="Password:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Column="4" Grid.Row="0" 
                             Style="{StaticResource FormTextBoxStyle}"
                             Text="{Binding CurrentVolunteer.Password, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}"/>

                        <CheckBox Grid.Column="4" Grid.Row="4" 
                              HorizontalAlignment="Center" VerticalAlignment="Bottom"
                              Content="Active Volunteer" 
                              Style="{StaticResource FormCheckBoxStyle}"
                            IsChecked="{Binding CurrentVolunteer.IsActive, Mode=TwoWay}"
                            IsEnabled="{Binding CurrentVolunteer.InCall, Converter={StaticResource ConvertActiveIsEnableKey}}"/>
                    </Grid>
                </GroupBox>
                <GroupBox Header="Total calls" Grid.Row="2" Style="{StaticResource FormGroupBoxStyle}"
                      Visibility="{Binding ButtonText, Converter={StaticResource ConvertUpdateToVisibleKey}}" Margin="2,3,2,3">
                    <Grid Margin="2.5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0"
                           Content="{Binding CurrentVolunteer.HandleCalls}" 
                           ContentStringFormat="Handled: {0}"
                           Style="{StaticResource FormLabelStyle}"
                               FontSize="14"
                               HorizontalAlignment="Center"/>
                        <Label Grid.Column="1"
                           Content="{Binding CurrentVolunteer.CancelCalls}" 
                           ContentStringFormat="Canceled: {0}"
                           Style="{StaticResource FormLabelStyle}"
                                FontSize="14"
                               HorizontalAlignment="Center"/>
                        <Label Grid.Column="2"
                           Content="{Binding CurrentVolunteer.ExpiredCalls}" 
                           ContentStringFormat="Expired: {0}"
                           Style="{StaticResource FormLabelStyle}"
                                FontSize="14"
                               HorizontalAlignment="Center"/>
                    </Grid>
                </GroupBox>
                <!-- Call Details Section -->
                <GroupBox Header="Current Call Details" Grid.Row="3" Style="{StaticResource FormGroupBoxStyle}"
                     Visibility="{Binding ButtonText, Converter={StaticResource ConvertUpdateToVisibleKey}}" Margin="2,2,2,2">
                    <Grid Margin="2.5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4.5*"/>
                            <ColumnDefinition Width="7.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="4.5*"/>
                            <ColumnDefinition Width="7.5*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>

                        </Grid.RowDefinitions>

                        <!-- Call Details Fields -->
                        <Label Grid.Row="0" Grid.Column="0"
                           Content="Call ID:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding CurrentVolunteer.InCall.CallId}" 
                             Style="{StaticResource FormTextBoxStyle}"  
                             IsReadOnly="True"/>

                        <Label Grid.Row="1" Grid.Column="0" 
                           Content="Type:" 
                           Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" 
                             Text="{Binding CurrentVolunteer.InCall.CallType}" 
                             Style="{StaticResource FormTextBoxStyle}" 
                             IsReadOnly="True"/>

                        <Label Grid.Row="2" Grid.Column="0"
                           Content="Description:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding CurrentVolunteer.InCall.Description}" 
                             Style="{StaticResource FormTextBoxStyle}" 
                             IsReadOnly="True" 
                             MouseEnter="ShowDescription">
                            <TextBox.ToolTip>
                                <ToolTip Content="{Binding CurrentVolunteer.InCall.Description}" 
                                     Background="{StaticResource CreamColor}"
                                     BorderBrush="{StaticResource AyeletHardColor}"
                                     Foreground="{StaticResource AyeletHardColor}"
                                         FontSize="16"/>
                            </TextBox.ToolTip>
                        </TextBox>

                        <Label  Grid.Row="3" Grid.Column="0"
                            Content="Address:" 
                            Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="1"
                             Text="{Binding CurrentVolunteer.InCall.CallAddress}" 
                             Style="{StaticResource FormTextBoxStyle}" 
                             IsReadOnly="True"/>

                        <Label  Grid.Row="0" Grid.Column="3"
                            Content="Status:" 
                            Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="0" Grid.Column="4"
                             Text="{Binding CurrentVolunteer.InCall.Status}" 
                             Style="{StaticResource FormTextBoxStyle}"  
                             IsReadOnly="True"/>

                        <Label Grid.Row="1" Grid.Column="3"
                           Content="Distance:" 
                           Style="{StaticResource FormLabelStyle}" />
                        <TextBox Grid.Row="1" Grid.Column="4"
                             Text="{Binding CurrentVolunteer.InCall.VolDistance}" 
                             Style="{StaticResource FormTextBoxStyle}" 
                             IsReadOnly="True"/>

                        <Label Grid.Row="2" Grid.Column="3"
                           Content="Open Time:" 
                           Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="4"
                             Text="{Binding CurrentVolunteer.InCall.OpenTime}" 
                             Style="{StaticResource FormTextBoxStyle}" 
                             IsReadOnly="True"/>

                        <Label Grid.Row="3" Grid.Column="3"
                           Content="Entry Time:" 
                           Style="{StaticResource FormLabelStyle}"/>
                        <TextBox Grid.Row="3" Grid.Column="4"
                             Text="{Binding CurrentVolunteer.InCall.EntryTime}" 
                             Style="{StaticResource FormTextBoxStyle}" 
                             IsReadOnly="True"/>
                    </Grid>
                </GroupBox>

                <!-- Action Button -->
                <Button Content="{Binding ButtonText}" Grid.Row="4" 
                    Style="{StaticResource MainButtonStyle}"
                    Click="btnAddUpdate_Click" Margin="270,10,270,10"/>
                
                <Button Style="{StaticResource BackArrowButton}"
                        Click="BackButton_Click"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Panel.ZIndex="1" Grid.Row="4"/>

            </Grid>
        </Border>
    </Grid>
</Window>