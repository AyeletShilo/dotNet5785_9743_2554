<Application x:Class="PL.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PL"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <local:FilterByCall x:Key="FilterByCallKey"/>
        <local:RoleOpt x:Key="RoleOptKey"/>
        <local:ConvertUpdateToTrue x:Key="ConvertUpdateToTrueKey"/>
        <local:ConvertUpdateToVisible x:Key="ConvertUpdateToVisibleKey"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverterKey"/>
        <local:FilterCall x:Key = "FilterCallKey" />
        <local:SortCall x:Key="SortCallKey"/>
        <local:StatusCall x:Key = "StatusCallKey" />
        <local:TypeCall x:Key = "TypeCallKey" />
        <local:SortVolunteer x:Key= "SortVolunteerKey"/>
        <local:CloseCallData x:Key="CloseCallsSortKey"/>
        <local:OpenCallData x:Key="OpenCallsSortKey"/>
        <local:ConvertUpdateDetails x:Key = "ConvertUpdateDetailsKey" />
        <local:ConvertUpdateMaxTime x:Key = "ConvertUpdateMaxTimeKey" />
        <local:ConvertUpdateType x:Key = "ConvertUpdateTypeKey" />
        <local:ConvertActiveIsEnable x:Key="ConvertActiveIsEnableKey"/>
        <local:MultiToIsEnabledConverter x:Key="MultiToIsEnabledConverterKey"/>

    </Application.Resources>
</Application>
