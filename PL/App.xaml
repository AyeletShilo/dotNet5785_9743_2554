<Application x:Class="PL.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PL"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <local:FilterByCall x:Key="FilterByCallKey"/>
        <local:RoleOpt x:Key="RoleOptKey"/>
        <local:ConvertUpdateToTrue x:Key="ConvertUpdateToTrueKey"/>
        <local:ConvertUpdateToVisible x:Key="ConvertUpdateToVisibleKey"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverterKey"/>
        <local:FilterCall x:Key = "FilterCallKey" />
        <local:SortCall x:Key="SortCallKey"/>
        <local:StatusCall x:Key = "StatusCallKey" />
        <local:TypeCall x:Key = "TypeCallKey" />
        <local:SortVolunteer x:Key= "SortVolunteerKey"/>
        <local:CloseCallData x:Key="CloseCallsSortKey"/>
        <local:OpenCallData x:Key="OpenCallsSortKey"/>
        <local:ConvertStatusToVisible x:Key="ConvertStatusToVisibleKey"/>
        <local:ConvertUpdateDetails x:Key = "ConvertUpdateDetailsKey" />
        <local:ConvertUpdateMaxTime x:Key = "ConvertUpdateMaxTimeKey" />
        <local:ConvertUpdateType x:Key = "ConvertUpdateTypeKey" />
        <local:ConvertActiveIsEnable x:Key="ConvertActiveIsEnableKey"/>
        <local:MultiToIsEnabledConverter x:Key="MultiToIsEnabledConverterKey"/>
        <local:ConvertCallTypeToColor x:Key="ConvertCallTypeToColorKey" />
        <local:ConvertStatusToColor x:Key="ConvertStatusToColorKey"/>
        <local:ConvertVolTypeToColor x:Key="ConvertVolTypeToColorKey"/>

        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Guttman Miryam"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#7D2216"/>
            <Setter Property="HorizontalAlignment" Value ="Center"/>
            
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontFamily" Value= "Sylfaen"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Background" Value="#FF7AD1B1"/>
            <Setter Property="Foreground" Value="#FF952828"/>
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="FrankRuehl"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="FrankRuehl"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            
        </Style>

        <Style x:Key="TextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontFamily" Value="Guttman Miryam"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="Black"/>
        </Style>

      
    </Application.Resources>
</Application>
