<Window x:Class="PL.Call.CallDescriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="Description" Height="350" Width="450"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Background="{StaticResource CreamColor}" Icon="/Image/BigIcon.ico">
   
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <GroupBox Header="{Binding CallType}" Style="{StaticResource FormGroupBoxStyle}" Margin="20">
            <TextBlock Text="{Binding Description}" Margin="20" TextWrapping="Wrap"/>
            <!--<Image Source="{Binding DescriptionType, Converter={StaticResource DesForImageKey}}"/>-->
        </GroupBox>
        <Image Source="{Binding CallType, Converter={StaticResource ConvertCallTypeToPitcherKey}}" Margin="120,171,120,19" Grid.RowSpan="2"/>


    </Grid>
</Window>
