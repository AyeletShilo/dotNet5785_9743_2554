<Window x:Class="PL.Call.CallDescriptionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="Description" Height="450" Width="450"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Background="{StaticResource CreamColor}">
   
    <Grid>
        <Grid.RowDefinitions>
            
        </Grid.RowDefinitions>
        <GroupBox Header="Description" Style="{StaticResource FormGroupBoxStyle}" Margin="20">
            <!--<Image Source="{Binding DescriptionType, Converter={StaticResource DesForImageKey}}"/>-->
        </GroupBox>
        
        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Description}" Margin="94,60,94,60"/>
    </Grid>
</Window>
