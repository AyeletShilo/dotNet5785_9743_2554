<Window x:Class="PL.Call.CallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="CallWindow" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Closed="Window_Closed"
        Loaded="Window_Loaded" 
        Background="{StaticResource CreamColor}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="109*"/>
            <RowDefinition Height="71*"/>
            <RowDefinition Height="28*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Padding="10" Margin="20,20,20,20" CornerRadius="8" Background="{StaticResource AyeletLightColor}">
            <GroupBox Header="Call Details" Style="{StaticResource FormGroupBoxStyle}" Margin="2">
                <Grid Margin="2.5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="7.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="7.5*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="2*"/>

                    </Grid.RowDefinitions>

                    <Label Content="ID:" 
                           Grid.Column="0" Grid.Row="0"
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="1" Grid.Row="0" 
                             MaxLength="9" IsReadOnly= "True" 
                             Text="{Binding CurrentCall.Id, Mode=TwoWay, NotifyOnValidationError=true, ValidatesOnExceptions=true}"
                             Style="{StaticResource FormTextBoxStyle}"/>

                    <Label Content="Call Type:" 
                           Grid.Column="0" Grid.Row="1" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox  Grid.Column="1" Grid.Row="1" 
                               SelectedValue="{Binding CurrentCall.CallType,  Mode=TwoWay, NotifyOnValidationError=true}" 
                               IsEnabled="{Binding CurrentCall.Status, Converter={StaticResource ConvertUpdateTypeKey}}" 
                               ItemsSource="{Binding Source={StaticResource TypeCallKey}}"
                               BorderBrush="Black" OpacityMask="#FF090909"/>



                    <Label Content="Call Address:" 
                           Grid.Column="0" Grid.Row="2"
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="1" Grid.Row="2" 
                             Text="{Binding CurrentCall.CallAddress, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                             IsReadOnly="{Binding CurrentCall.Status, Converter={StaticResource ConvertUpdateDetailsKey}}" 
                             Style="{StaticResource FormTextBoxStyle}">
                        <TextBox.ToolTip>
                            <ToolTip Width="Auto" Height="Auto" BorderBrush="{StaticResource AyeletHardColor}"  Background="{StaticResource CreamColor}"
                                     Foreground="{StaticResource AyeletHardColor}">

                                <Border BorderBrush="Transparent" BorderThickness="1" Padding="5">
                                    <TextBlock TextWrapping="NoWrap" Text="{Binding CurrentCall.CallAddress, Mode=OneWay}" FontSize="14"/>
                                </Border>
                            </ToolTip>
                        </TextBox.ToolTip>
                    </TextBox>
                    <Label Content="Description:" 
                Grid.Column="0" Grid.Row="3" 
                Style="{StaticResource FormLabelStyle}" VerticalAlignment="Top" Margin="5"/>
                    <TextBox Grid.Column="1" Grid.Row="3" Grid.ColumnSpan="4"
                  Text="{Binding CurrentCall.Description, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                  MaxLength="10" IsReadOnly="{Binding CurrentCall.Status, Converter={StaticResource ConvertUpdateDetailsKey}}"
                  Style="{StaticResource FormTextBoxStyle}" VerticalContentAlignment="Top"
                             TextWrapping="Wrap"  Height="70"
         AcceptsReturn="False"
         VerticalScrollBarVisibility="Hidden" Margin="0,5">
                        <!--<TextBox.ToolTip>
                            <ToolTip Width="200" BorderBrush="{StaticResource AyeletHardColor}"  Background="{StaticResource CreamColor}"
                                     Foreground="{StaticResource AyeletHardColor}">

                                <Border BorderBrush="Transparent" BorderThickness="1" Padding="5">
                                    <TextBlock TextWrapping="Wrap" Text="{Binding CurrentCall.Description, Mode=OneWay}" FontSize="14"/>
                                </Border>
                            </ToolTip>
                        </TextBox.ToolTip>-->
                    </TextBox>

                    <Label Content="Open time:" 
                           Grid.Column="3" Grid.Row="0"
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="3" Grid.Row="0"
                             Text="{Binding CurrentCall.OpenTime, StringFormat='{}{0:dd/MM/yy HH:mm}', Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                             IsReadOnly ="True" Style="{StaticResource FormTextBoxStyle}" Grid.ColumnSpan="2" Height="30" Margin="126,5,0,0" VerticalAlignment="Top"/>

                    <Label Content="Max Time:" 
                           Grid.Column="3" Grid.Row="1" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="4" Grid.Row="1" 
                             Text="{Binding CurrentCall.MaxCloseTime,  StringFormat='{}{0:dd/MM/yy HH:mm}', Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}"
                             IsReadOnly="{Binding CurrentCall.Status, Converter={StaticResource ConvertUpdateMaxTimeKey}}"
                             Style="{StaticResource FormTextBoxStyle}"/>

                    <Label Content="Call status:" 
                           Grid.Column="3" Grid.Row="2"
                           Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox  Grid.Column="4" Grid.Row="2" 
                               SelectedValue="{Binding CurrentCall.Status,  Mode=TwoWay, NotifyOnValidationError=true}"
                               ItemsSource="{Binding Source={StaticResource StatusCallKey}}" 
                               IsEnabled="False" 
                               BorderBrush= "Black" OpacityMask="#FF090909"/>
                    <!--SelectionChanged="ComboBox_SelectionChanged"-->

                </Grid>
            </GroupBox>
        </Border>

        <GroupBox Header="Call Assignments" Grid.Row="1" Padding="7" Margin="20,10,20,20" 
                  Style="{StaticResource FormGroupBoxStyle}" Background="Transparent">
            <DataGrid  ItemsSource="{Binding Path=CurrentCall.CallAssignments}" 
                       IsReadOnly ="True"
                       RowDetailsVisibilityMode="VisibleWhenSelected"
                       Style="{StaticResource DataStyle}"
                       CellStyle="{StaticResource CenteredDataGridCellStyle}">

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding VolunteerId}" Header=" volunteer Id" Width="*" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding VolunteerName}" Header="volunteer name" Width="*"/>
                    <DataGridTextColumn Binding="{Binding InterTime, StringFormat='{}{0:dd/MM/yy}'}" Header="entry Time" Width="*"/>
                    <DataGridTextColumn Binding="{Binding EndTime, StringFormat='{}{0:dd/MM/yy HH:mm}'}" Header="end Time" Width="*"/>
                    <DataGridTextColumn Binding="{Binding EndTreatment}" Header="treatment status" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
        <Button Grid.Row="2"
                Content="Update" 
                Click="btnUpdate_Click"  
                Margin="270,10,270,10"
                Style="{StaticResource MainButtonStyle}"
                IsEnabled="{Binding CurrentCall.Status, Converter={StaticResource ConvertUpdateEnableKey}, Mode=TwoWay}"/>

        <Button Style="{StaticResource BackArrowButton}"
                Click="BackButton_Click"
                HorizontalAlignment="Left"
                Grid.Row="2"
                Panel.ZIndex="1"
                VerticalAlignment="Bottom"
                Margin="15,0,0,15" Height="40" Width="40"/>

    </Grid>
</Window>
