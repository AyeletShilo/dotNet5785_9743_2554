<Window x:Class="PL.Call.CallListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="CallListWindow" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Closed="Window_Closed"
        Loaded="Window_Loaded"
        Background="{StaticResource CreamColor}" Icon="/Image/BigIcon.ico">

    
    <Grid Margin="15,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="59"/>
            <RowDefinition Height="416*"/>
            <RowDefinition Height="Auto" MinHeight="84.04"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Label Content="Filter by:" 
               Style="{StaticResource HeaderLabelStyle}"
               Grid.Column="0"
               Margin="40,0,0,0" Visibility= "{Binding Path= IsFilter,Converter={StaticResource ConvertStatusToVisibleKey}}"/>


            <ComboBox Grid.Column="1" Margin="20,0"
                  SelectedValue="{Binding Path=CallFilter, Mode=TwoWay}"
                  ItemsSource="{Binding Source={StaticResource FilterCallKey}}"
                  SelectionChanged="Filter_SelectionChanged" Visibility= "{Binding Path= IsFilter,Converter={StaticResource ConvertStatusToVisibleKey}}"/>

            <Label Content="Sort by:" 
               Style="{StaticResource HeaderLabelStyle}"
               Grid.Column="2"
               Margin="40,0,0,0"/>

            <ComboBox Grid.Column="3" Margin="20,0"
                  SelectedValue="{Binding Path=CallSort, Mode=TwoWay}"
                  ItemsSource="{Binding Source={StaticResource SortCallKey}}"
                  SelectionChanged="Sort_SelectionChanged"/>

        </Grid>

        <DataGrid Grid.Row="1" 
                  Margin="0,15,0,15" 
                  ItemsSource="{Binding Path=CallList}" 
                  SelectedItem="{Binding SelectedCall}"
                  MouseDoubleClick="lsvCallsList_MouseDoubleClick"
                  Style="{StaticResource DataStyle}"
                  CellStyle="{StaticResource CenteredDataGridCellStyle}">

            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding CallId}" Header=" Call Id" Width="auto" >
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding CallType}" Header="Call Type" Width="auto">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Background" Value="{Binding Path = CallType, Converter={StaticResource ConvertCallTypeToColorKey}}" />
                            <Setter Property="Foreground" Value="{Binding Path= CallType, Converter={StaticResource ConvertFontColorKey}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="Left Time" Width="auto">
                    <DataGridTextColumn.Binding>
                        <Binding Path="LeftTime" Converter="{StaticResource TimeSpanToStringConverterKey}" />
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn  Header="Complate At" Width="3*">
                    <DataGridTextColumn.Binding>
                        <Binding Path="CompletionTime" Converter="{StaticResource TimeSpanToDateConverterKey}" />
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding Status}" Header="Status" Width="2*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Background" Value="{Binding Path = Status, Converter={StaticResource ConvertStatusToColorKey}}" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding TotalAssignments}" Header="Assignments" Width="auto"/>
                <DataGridTextColumn Binding="{Binding LastVolunteer}" Header="Last Volunteer" Width="auto"/>
                <DataGridTemplateColumn Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Click="Delete_Call"
                                    Style="{StaticResource DeleteButton}"
                                    Visibility="{Binding Path=. ,Converter={StaticResource ConvertDeleteToVisibleKey}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Width="auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Click="Cancel_Call" Content="cancel" 
                                    Style="{StaticResource CancleButton}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <Button Grid.Row="2"
                Content="Add New Call"
                Click="lsvCallList_AddCall"
                Margin="270,10"
                Style="{StaticResource MainButtonStyle}"/>
        
        <Button Style="{StaticResource BackArrowButton}"
                Click="BackButton_Click"
                HorizontalAlignment="Left"
                Grid.Row="2"
                Panel.ZIndex="1"
                VerticalAlignment="Bottom"/>
    </Grid>
</Window>
