<Window x:Class="PL.Call.AddCall"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="AddCall" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Background="{StaticResource CreamColor}">


    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="282.53"/>
            <RowDefinition Height="50*"/>
            <RowDefinition Height="121*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource AyeletLightColor}" Padding="10" Margin="20,60,20,40" CornerRadius="8">
            <GroupBox Header="Call Details" Margin="5" Style="{StaticResource FormGroupBoxStyle}">
                <Grid Margin="2.5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="7.5*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="4.5*"/>
                        <ColumnDefinition Width="7.5*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Label Content="Call Type:" 
                           Grid.Column="0" Grid.Row="0" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox  Grid.Column="1" Grid.Row="0" 
                               SelectedValue="{Binding CurrentCall.CallType,  Mode=TwoWay, NotifyOnValidationError=true}"
                               ItemsSource="{Binding Source={StaticResource TypeCallKey}}" 
                               Margin="0,5" BorderBrush="Black" OpacityMask="#FF090909"/>

                    <Label Content="Description:" 
                           Grid.Column="0" Grid.Row="1"
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="1" Grid.Row="1" 
                             Text="{Binding CurrentCall.Description, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                             Style="{StaticResource FormTextBoxStyle}"/>

                    <Label Content="Call Address:" 
                           Grid.Column="0" Grid.Row="2" 
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="1" Grid.Row="2"
                             Text="{Binding CurrentCall.CallAddress, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                             Style="{StaticResource FormTextBoxStyle}"/>

                    <Label Content="Open time:" 
                           Grid.Column="3" Grid.Row="0"
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="4" Grid.Row="0"
                             Text="{Binding CurrentCall.OpenTime, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                             IsReadOnly ="True" Style="{StaticResource FormTextBoxStyle}"/>

                    <Label Content="Max Time:" 
                           Grid.Column="3" Grid.Row="1"
                           Style="{StaticResource FormLabelStyle}"/>
                    <TextBox Grid.Column="4" Grid.Row="1" VerticalAlignment="Center"
                        Text="{Binding CurrentCall.MaxCloseTime, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" 
                        IsReadOnly ="false" Style="{StaticResource FormTextBoxStyle}"/>
                    <!--<StackPanel  Grid.Column="4" Grid.Row="1" VerticalAlignment="Center">
                        <DatePicker DisplayDateStart="{Binding CurrentTime}"
                                    DisplayDateEnd="{Binding CurrentTime, Converter={StaticResource MaxTimeForEndTimeConverterKey}}"
                                    SelectedDate="{Binding CurrentCall.MaxCloseTime, Mode=TwoWay}"
                                    Foreground="{StaticResource HardestGreenColor}">
                            <DatePicker.BlackoutDates>
                                <CalendarDateRange Start="{Binding CurrentTime}"
                                                   End="{Binding CurrentTime, Converter={StaticResource MaxTimeForEndTimeConverterKey}}" />
                            </DatePicker.BlackoutDates>

                        </DatePicker>
                    </StackPanel>-->

                    <!--<Label Content="Call status:" 
                           Grid.Column="3" Grid.Row="3"
                           Style="{StaticResource FormLabelStyle}"/>
                    <ComboBox  Grid.Column="4" Grid.Row="3" 
                               SelectedValue="{Binding CurrentCall.Status,  Mode=TwoWay, NotifyOnValidationError=true}"
                               ItemsSource="{Binding Source={StaticResource StatusCallKey}}" 
                               Margin="0,5" BorderBrush= "Black" OpacityMask="#FF090909" IsEnabled="False"/>-->



                    <!--<TextBox Grid.Column="4" Grid.Row="2" 
     Text="{Binding CurrentCall.MaxCloseTime, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}"/>-->

                </Grid>
            </GroupBox>
        </Border>

        <Button Grid.Row="1"
                Content="Add Call" 
                Click="bthAdd_Click" 
                Style="{StaticResource MainButtonStyle}"
                Margin="270,10"/>
        <Button Style="{StaticResource BackArrowButton}"
                Click="BackButton_Click"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                Margin="5,0,0,20"
                Panel.ZIndex="1" Grid.Row="3"/>

    </Grid>

</Window>
