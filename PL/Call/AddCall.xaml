<Window x:Class="PL.Call.AddCall"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="AddCall" Height="450" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Closed="Window_Closed"
        Loaded="Window_Loaded">
    <Window.Background>
        <ImageBrush ImageSource="C:\Users\Administrator\source\repos\newOne\PL\Image\Background (2).png"/>
    </Window.Background>
    <Window.Resources>
        <Style TargetType="Label" BasedOn="{StaticResource LabelStyle}"/>
        <Style TargetType="TextBox" BasedOn="{StaticResource TextBoxStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style TargetType="ComboBox" BasedOn="{StaticResource  ComboBoxStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>
    </Window.Resources>





    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="205*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5,5,5,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="10*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="10*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="35*"/>
                <RowDefinition Height="35*"/>
            </Grid.RowDefinitions>

            <Label Content="Add call details:" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="5"  FontWeight ="Bold" FontSize="32" HorizontalAlignment="Center"/>
            <Label Content="Call Type:" Grid.Column="0" Grid.Row="1" />
            <Label Content="Description:" Grid.Column="0" Grid.Row="2" />
            <Label Content="Call Address:" Grid.Column="0" Grid.Row="3" />
            <Label Content="Open time:" Grid.Column="3" Grid.Row="1" />
            <Label Content="Max Time to close:" Grid.Column="3" Grid.Row="2" />
            <Label Content="Call status:" Grid.Column="3" Grid.Row="3"/>


            <ComboBox  Grid.Column="1" Grid.Row="1" 
            SelectedValue="{Binding CurrentCall.CallType,  Mode=TwoWay, NotifyOnValidationError=true}"
            ItemsSource="{Binding Source={StaticResource TypeCallKey}}" BorderBrush="Black" OpacityMask="#FF090909"/>
            <TextBox Grid.Column="1" Grid.Row="2" 
             Text="{Binding CurrentCall.Description, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" MaxLength="10"/>
            <TextBox Grid.Column="1" Grid.Row="3" 
             Text="{Binding CurrentCall.CallAddress, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" />
            <TextBox Grid.Column="4" Grid.Row="1"
             Text="{Binding CurrentCall.OpenTime, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}" IsReadOnly ="True"/>
            <TextBox Grid.Column="4" Grid.Row="2" 
             Text="{Binding CurrentCall.MaxCloseTime, Mode=TwoWay, NotifyOnValidationError=true,  ValidatesOnExceptions=true}"/>
            <ComboBox  Grid.Column="4" Grid.Row="3" 
            SelectedValue="{Binding CurrentCall.Status,  Mode=TwoWay, NotifyOnValidationError=true}"
            ItemsSource="{Binding Source={StaticResource StatusCallKey}}" BorderBrush= "Black" OpacityMask="#FF090909" IsEnabled="False"/>
        </Grid>

        <Button Content="Add Call" Click="bthAdd_Click" HorizontalAlignment="Center" VerticalAlignment="Top" Width="800" Height="63" Margin="0,358,0,0" Grid.RowSpan="3"/>

    </Grid>

</Window>
