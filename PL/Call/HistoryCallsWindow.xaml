<Window x:Class="PL.Call.HistoryCallsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="HistoryCallsWindow" Height="640" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Background="{StaticResource CreamColor}">


    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid HorizontalAlignment="Stretch" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!--#region Sort and Filter -->
            <Label Content="Filter by:" 
                   Style="{StaticResource HeaderLabelStyle}"
                   Grid.Column="0"
                   Margin="0,0,10,0"/>
            <ComboBox Grid.Column="1" 
                      SelectedValue="{Binding Path=CallFilter, Mode=TwoWay}"
                      ItemsSource="{Binding Source={StaticResource TypeCallKey}}"
                      SelectionChanged="Filter_SelectionChanged"/>
            <Label Content="Sort by:" 
                   Style="{StaticResource HeaderLabelStyle}"
                   Grid.Column="2"
                   Margin="20,0,10,0"/>
            <ComboBox Grid.Column="3"
                      SelectedValue="{Binding Path=CallSort, Mode=TwoWay}"
                      ItemsSource="{Binding Source={StaticResource CloseCallsSortKey}}" 
                      SelectionChanged="Sort_SelectionChanged"/>

            <!--#endregion-->
        </Grid>
        <DataGrid  Grid.Row="1"  
                   Margin="0,15"
                   ItemsSource="{Binding Path=CloseCallList}" 
                   SelectedItem="{Binding SelectedCall}"
                   Style="{StaticResource DataStyle}"
                   CellStyle="{StaticResource CenteredDataGridCellStyle}">
            
            <DataGrid.Columns>
                <DataGridTextColumn Binding="{Binding Id}" Header=" Call Id" Width="*" >
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Binding="{Binding CallType}" Header="Call Type" Width="*"/>
                <DataGridTextColumn Binding="{Binding FullAddress}" Header="Call Address" Width="2*"/>
                <DataGridTextColumn Binding="{Binding OpenTime, StringFormat='{}{0:dd/MM/yyyy}'}" Header="Open Time" Width="*"/>
                <DataGridTextColumn Binding="{Binding InterTime, StringFormat='{}{0:dd/MM/yyyy}'}" Header="Start at" Width="*"/>
                <DataGridTextColumn Binding="{Binding CloseTime, StringFormat='{}{0:dd/MM/yyyy HH:mm:ss}'}" Header="Close Time" Width="*"/>
                <DataGridTextColumn Binding="{Binding EndTreatment}" Header="Close at" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Style="{StaticResource BackArrowButton}"
                Grid.Row="2"
                Click="BackButton_Click"
                HorizontalAlignment="left"
                VerticalAlignment="Top"
                Margin="10,10,0,0"
                Panel.ZIndex="1"/>
    </Grid>
</Window>
