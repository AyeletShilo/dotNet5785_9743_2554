<Window x:Class="PL.Call.HistoryCallsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Call"
        mc:Ignorable="d"
        Title="HistoryCallsWindow" Height="450" Width="800"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}">
    <!--Closed="Window_Closed"-->
        <!--Loaded="Window_Loaded">-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="11*"/>
            <RowDefinition Height="418*"/>
            <RowDefinition Height="11*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="11*"/>
            <ColumnDefinition Width="782*"/>
            <ColumnDefinition Width="11*"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="31*"/>
                <RowDefinition Height="175*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ComboBox Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                      ItemsSource="{Binding Source={StaticResource CloseCallsSortKey}}"
                      SelectionChanged="ComboBoxSort_SelectionChanged"  SelectedValue="{Binding Path=CallSort, Mode=TwoWay}">
            </ComboBox>
            <!--<Label Content="Label" HorizontalAlignment="Left" Margin="200,0,0,0" VerticalAlignment="Top" Grid.Column="0"/>-->
            <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                      ItemsSource="{Binding Source={StaticResource TypeCallKey}}"
                      SelectionChanged="ComboBoxFilter_SelectionChanged"  SelectedValue="{Binding Path=CallFilter, Mode=TwoWay}">
            </ComboBox>
            <DataGrid Margin="5" Grid.Row="1"  Grid.ColumnSpan="2" ItemsSource="{Binding Path=CloseCallList}" IsReadOnly ="True" AutoGenerateColumns="False"
 	          EnableRowVirtualization="True" RowDetailsVisibilityMode="VisibleWhenSelected"
              SelectedItem="{Binding SelectedCall}">
                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Id}" Header=" Call Id" Width="*" >
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Background" Value="LightCyan"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Binding="{Binding CallType}" Header="Call Type" Width="*"/>
                    <DataGridTextColumn Binding="{Binding FullAddress}" Header="Call Address" Width="2*"/>
                    <DataGridTextColumn Binding="{Binding OpenTime}" Header="Open Time" Width="*"/>
                    <DataGridTextColumn Binding="{Binding InterTime}" Header="Start at" Width="*"/>
                    <DataGridTextColumn Binding="{Binding CloseTime}" Header="Close Time" Width="*"/>
                    <DataGridTextColumn Binding="{Binding EndTreatment}" Header="Close at" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
       
</Window>
